" ====================================================================
" Functions
" ====================================================================
" --- Utilities ------------------------------------------------------
function! s:GetVisualText() abort
    let v = getreg('z') | let t = getregtype('z')
    try
        silent! normal! gv"zy
        return getreg('z')
    finally
        call setreg('z', v, t)
    endtry
endfunction

" 同IDはデバウンスし、最後のタイマーだけ実行する.
let s:defer_latest_tbl = {}
function! s:DeferLatest__Fire(id, _timer) abort
    if !has_key(s:defer_latest_tbl, a:id) | return | endif
    let entry = remove(s:defer_latest_tbl, a:id) " [timer, cb, args]
    call call(entry[1], entry[2])
endfunction
function! s:DeferLatest(id, ms, cb, ...) abort
    if has_key(s:defer_latest_tbl, a:id)
        call timer_stop(s:defer_latest_tbl[a:id][0])
    endif
    let timer = timer_start(a:ms, function('s:DeferLatest__Fire', [a:id]))
    if timer != -1
        let s:defer_latest_tbl[a:id] = [timer, a:cb, a:000]
    endif
    return timer
endfunction

function! s:FmtBytes(bytes) abort
    if a:bytes <= 0 | return '' | endif
    let u = ['B','K','M','G','T','P','E']
    let i = 0 | let v = str2float(a:bytes)
    while v >= 1024.0 | let v /= 1024.0 | let i += 1 | endwhile
    return i ? printf('%.1f%s', v, u[i]) : printf('%d%s', a:bytes, u[0])
endfunction

" ====================================================================
" Functions: Map
" ====================================================================
" Visual選択を検索レジスタ(@/)へセット(search_cmd: '/' or '?')
function! s:VisualSetSearch() abort
    let pat = escape(s:GetVisualText(), '\\/')
    if empty(pat) | return | endif
    let @/ = '\V' . substitute(pat, "\n", '\\n', 'g')
    if histget('search', -1) !=# @/ | call histadd('search', @/) | endif
    keepjumps normal! `<
endfunction

" <cWORD>を@/にセットして最初の位置にカーソル移動. (*の<cWORD>版)
function! s:CWORDSetSearch() abort
    let pat = escape(expand('<cWORD>'), '\\/')
    if empty(pat) | return | endif
    let @/ = '\V' . pat
    if histget('search', -1) !=# @/ | call histadd('search', @/) | endif
    let line = getline('.') | let i = col('.') - 1
    if line[i] =~# '\s'
        let motion = 'W'
    elseif i == 0 || line[i-1] =~# '\s'
        return
    else
        let motion = 'B'
    endif
    execute 'keepjumps normal! ' . motion
endfunction

" <C-v>での一括挿入をVの行モードにも追加.
let s:neo_visual_line_tbl =
            \ {'A': "\<C-v>0o$A", 'I': "\<C-v>^o^I", 'gI': "\<C-v>0o$I"}
function! s:NeoVisualLine(rhs) abort
    return mode() ==# 'V' ? s:neo_visual_line_tbl[a:rhs] : a:rhs
endfunction

function! s:ReIndentPut(rhs, reg, count) abort
    if a:rhs !~# '^g\?[pP]$' | return | endif
    let is_g = len(a:rhs) == 2
    execute 'normal! ' . a:count . '"' . a:reg . a:rhs
    let pos = getpos('.')
    if getregtype(a:reg) ==# 'V' && len(getreg(a:reg, 1, 1)) <= 500
        keepjumps normal! '[=']
        call setpos('.', pos)
        normal! ^
    endif
endfunction

function! s:YankBufnameOrFullPath() abort
    let path = expand('%:p') | let bufname = bufname('%')
    if empty(path) && empty(bufname) | echo 'No buffer name.' | return | endif
    let @+ = !empty(path) ? path : bufname
    echo 'Copied ' . (!empty(path) ? 'full path' : 'buffer name') . ' to @+.'
endfunction

" タブ移動. Countは[t系は繰り返し. [T系はそのIDのタブへ.
function! TabJump(kind) abort
    let last = tabpagenr('$')
    if last <= 1 | return | endif

    if a:kind ==# 'prev' || a:kind ==# 'next'
        let dir  = (a:kind ==# 'next') ? 1 : -1
        let cur  = tabpagenr() - 1 " 0-based
        " wrap-around
        let tabnr = ((((cur + dir * v:count1) % last) + last) % last) + 1
    elseif a:kind ==# 'first' || a:kind ==# 'last'
        let tabnr = v:count ? v:count : (a:kind ==# 'first' ? 1 : last)
        let tabnr = tabnr < 1 ? 1 : (tabnr > last ? last : tabnr)
    else
        return
    endif
    execute 'tabnext' tabnr
endfunction

" 空行を[count]行だけ挿入してカーソル位置/画面位置を完全に元に戻す.
function! s:PutBlankLines(below, count) abort
    let view = winsaveview()
    let c = a:count > 0 ? a:count : 1

    if a:below
        silent keepjumps keepmarks put =repeat(nr2char(10), c)
    else
        silent keepjumps keepmarks put!=repeat(nr2char(10), c)
        " 上に入れると元の行が l:c 行ぶん下にずれるので補正.
        let view.lnum += c
    endif

    call winrestview(view)
endfunction

" ドットリピート・カウント非対応.
function! s:CommentInsertAoO(cmd) abort
    if a:cmd !~# '^[AoO]$' | return | endif
    let cs = &l:commentstring
    if cs !~# '%s' | return | endif

    let i   = stridx(cs, '%s')
    let lhs = substitute(strpart(cs, 0, i), '<', '<LT>', 'g')
    let rhs = substitute(strpart(cs, i + 2), '<', '<LT>', 'g')

    if a:cmd ==# 'A'
        silent keepjumps keeppatterns s/[ \t]\+$//e
        if !empty(getline('.')) | let lhs = ' ' . lhs | endif
    endif

    let keys = a:cmd . lhs . rhs . repeat("\<C-g>U\<Left>", strchars(rhs))
    call feedkeys(keys , 'n')
endfunction

" Subword textobj: iS / aS.
let s:subword_pat = '\v(\u+(\ze\u\l)|\u?\l+|\u+|\d+)'
function! s:SubwordRange() abort
    let l = getline('.')
    let n = strlen(l)
    if n == 0 | return [0, 1] | endif

    let c = col('.') - 1
    if c < 0 | let c = 0 | endif
    if c >= n | let c = n - 1 | endif

    " delimiter上なら隣へ寄せる.
    if l[c] =~# '[_-]'
        if c+1 < n && l[c+1] =~# '\k' | let c += 1
        elseif c > 0 && l[c-1] =~# '\k' | let c -= 1
        else | return [c, c+1]
        endif
    endif

    let i = 0
    while 1
        let [m, s, e] = matchstrpos(l, s:subword_pat, i)
        if s < 0 | return [c, c+1] | endif
        if c >= s && c < e | return [s, e] | endif
        if s > c | return [c, c+1] | endif
        let i = e
    endwhile
endfunction
function! s:SelectSubword(around) abort
    let [s, e] = s:SubwordRange()
    let l = getline('.')
    let n = strlen(l)

    if a:around
        let left  = (s > 0 && l[s-1] =~# '[_-]')
        let right = (e < n && l[e]   =~# '[_-]')

        " ルール:
        " - 前があるなら前を含める. (前後にあっても前だけ)
        " - 前がなくて後ろだけなら後ろを含める.
        if left
            let s -= 1
        elseif right
            let e += 1
        endif
    endif

    call setpos("'<", [0, line('.'), s+1, 0])
    call setpos("'>", [0, line('.'), e,   0])
    normal! `<v`>
endfunction

