" ====================================================================
" Single-file vimrc (Vim 8.0+ and Neovim latest stable)
" ====================================================================
scriptencoding utf-8

if v:version < 800
    echohl WarningMsg
    echomsg 'WARNING: This vimrc targets Vim 8.0+ (and Neovim).' .
                \ ' Some settings may be ignored or may error.'
    echohl None
endif

if has('win32') || has('win64')
    let s:is_root = 0
elseif has('nvim')
    let s:is_root = !!luaeval('vim.uv.getuid() == 0')
elseif executable('id')
    let s:is_root = trim(system('id -u')) ==# '0'
else
    let s:is_root = exists('$USER') && $USER ==# 'root'
endif

if s:is_root
    set nomodeline
    set secure
endif
set noexrc

let s:is_vim = !has('nvim')
let s:is_nvim = has('nvim')
let s:is_ext_nvim = get(g:, 'is_extended_nvim', 0)

" ====================================================================
" Options
" ====================================================================
set encoding=utf-8
set fileencoding=utf-8
set fileencodings=ucs-bom,utf-8,cp932,default,latin1

set mouse=a
set belloff=all
set shortmess=aoOtTCFI

set number
set numberwidth=4
set relativenumber
set cursorline
if exists('+cursorlineopt')
    set cursorlineopt=number
endif
set signcolumn=yes

set list " 不可視文字を表示.
set listchars=eol:↴,extends:…,nbsp:+,precedes:…,space:⋅,tab:>\ ,trail:-
set ambiwidth=single
set scrolloff=3
set sidescrolloff=3

set expandtab
set tabstop=8 " Tab文字の表示幅. 互換性の為8固定推奨(らしい)
set shiftwidth=4
set softtabstop=-1 " 負の数指定でshiftwidthの値を使用.

set hidden " バッファの切替で未保存で止められない.
set virtualedit=block " Visual blockで仮想空白を許可.
set nowrap
set formatoptions-=ro  " コメント継続を禁止. r:挿入モード o:o/Oコマンド.

set splitbelow
set splitright

set ignorecase
set smartcase
set hlsearch
set incsearch
if s:is_nvim
    set inccommand=split
endif
if executable('rg')
    set grepprg=rg\ --vimgrep\ --smart-case\ --hidden\ --no-messages
                \\ --glob\ '!.git/*'
    set grepformat=%f:%l:%c:%m
endif

set wildmenu
set wildmode=longest:full,full
set wildignorecase
set wildignore+=*/.git/*,*/node_modules/*,*/__pycache__/*
set wildignore+=*.swp,*.swo,*.tmp,*.bak,*.orig
if s:is_nvim || has('patch-8.2.4463') " Vim: since 2022-02-24.
    set wildoptions=pum,tagfile,fuzzy
endif

set complete=.,w,b,u,t,i
set completeopt=menuone,noselect
" popup自体は8.1.1880 関連オプションのcompletepopupが導入されたのがこのパッチ.
if s:is_nvim || has('patch-8.1.1882') " Vim: since 2019-08-18.
    set completeopt+=popup
else
    set completeopt+=preview
endif
if s:is_nvim || has('patch-9.1.0463') " Vim: since 2024-06-03.
    set completeopt+=fuzzy
endif

set pumheight=15
if exists('&pumwidth') | set pumwidth=20 | endif " Vim 8.0.1491+
if exists('&pummaxwidth') | set pummaxwidth=60 | endif " Vim 9.1.1250+
if exists('&pumblend') | set pumblend=10 | endif " Neovim only.

set timeoutlen=800 " マッピングの待ち時間.
set ttimeoutlen=50 " 端末から来るキーコードの待ち時間.
set updatetime=1000

" ====================================================================
" Features
" ====================================================================
" --- XDG paths ------------------------------------------------------
if !s:is_root
    let s:cache_home = empty($XDG_CACHE_HOME) ?
                \ expand('~/.cache') : $XDG_CACHE_HOME
    let s:state_home = empty($XDG_STATE_HOME) ?
                \ expand('~/.local/state') : $XDG_STATE_HOME
else
    let s:root_home = expand('~root')
    if empty(s:root_home) || !isdirectory(s:root_home)
        let s:root_home = (has('mac') ? '/private/var/root' : '/root')
    endif
    let s:cache_home = s:root_home . '/.cache'
    let s:state_home = s:root_home . '/.local/state'
endif
let s:cache_path = s:cache_home . '/' . (s:is_nvim ? 'nvim' : 'vim')
let s:state_path = s:state_home . '/' . (s:is_nvim ? 'nvim' : 'vim')

function! s:EnsureDir(dir) abort
    if empty(a:dir) | return 0 | endif
    let ok = isdirectory(a:dir)
    if !ok
        silent! call mkdir(a:dir, 'p', 0700)
        let ok = isdirectory(a:dir)
    endif
    return ok
endfunction
" ディレクトリのパーミッションを可能なら0700に設定. 戻り値はEnsureDirと同じ.
function! s:EnsureDirSecure(dir) abort
    let ok = s:EnsureDir(a:dir)
    if ok && !s:is_root
        let perm = getfperm(a:dir)
        if !empty(perm) && perm !=# 'rwx------'
            silent! call setfperm(a:dir, 'rwx------')
        endif
    endif
    return ok
endfunction

" --- Swap -----------------------------------------------------------
let s:swap_dir = s:state_path . '/swap'
if s:EnsureDirSecure(s:swap_dir)
    let s:swap_dir_escape = escape(s:swap_dir, ',\\')
    let &directory = s:swap_dir_escape . '//,' . s:swap_dir_escape . ',.'
endif

" --- Backup ---------------------------------------------------------
set nobackup
set writebackup
let s:backup_dir = s:state_path . '/backup'
if s:EnsureDirSecure(s:backup_dir)
    let s:backup_dir_cache = escape(s:backup_dir, ',\\')
    let &backupdir = s:backup_dir_cache . '//,' . s:backup_dir_cache . ',.'
endif

" --- Persistent undo ------------------------------------------------
if has('persistent_undo') && !s:is_root
    let s:undo_dir = s:state_path . '/undo'
    if s:EnsureDirSecure(s:undo_dir)
        set undofile
        " undodirは末尾に//がなくてもユニーク名になる.
        let &undodir = s:undo_dir
    endif
endif

" --- Viminfo / ShaDa ------------------------------------------------
if has('shada')
    let s:shada_dir = s:state_path . '/shada'
    if s:EnsureDirSecure(s:shada_dir)
        set history=10000
        let &shadafile = s:shada_dir . '/main.shada'
        let &shada = "!,'1000,<500,:5000,/500,@100,s50,h"
    endif
elseif has('viminfo')
    let s:viminfo_dir = s:state_path . '/viminfo'
    if s:EnsureDirSecure(s:viminfo_dir)
        set history=500
        let &viminfofile = s:viminfo_dir . '/main.viminfo'
        let &viminfo = "'100,<100,:500,/200,@100,s20,h"
    endif
endif

" --- Smart relativenumber -------------------------------------------
augroup vimrc_smart_relativenumber
    autocmd!
    autocmd BufEnter,FocusGained,InsertLeave,CmdlineLeave,WinEnter
    \   * if &number && mode() != 'i' | set relativenumber | endif
    autocmd BufLeave,FocusLost,InsertEnter,CmdlineEnter,WinLeave
    \   * if &number | set norelativenumber | if !exists('g:vscode') |
    \   redraw | endif | endif
augroup END

" スクロール中だけ絶対行にする.
if exists('##WinScrolled') && has('timers')
    augroup vimrc_smart_relativenumber_scroll
        autocmd!
        autocmd WinScrolled * call s:RelNumOnScroll()
    augroup END
endif

" --- Stop E173 ------------------------------------------------------
" 起動時にarglistを現在のバッファだけにする.
augroup vimrc_arglist_keep_first
    autocmd!
    autocmd VimEnter * if argc() > 1 | silent! args % | endif
augroup END

" --- Remove ro from formatoptions -----------------------------------
" コメント継続を切る. FileTypeイベント発生の500ms後にroを除いたfoをセット.
if has('timers')
    augroup vimrc_remove_ro_from_formatoptions
        autocmd!
        autocmd FileType * if empty(&buftype) |
                    \ call s:DeferLatest(
                    \   's:RemoveROFromFO_' . expand('<abuf>'), 500,
                    \   function('s:RemoveROFromFO', [expand('<abuf>')])
                    \ ) |
                    \ endif
    augroup END
endif

" --- Statusline -----------------------------------------------------
if !s:is_ext_nvim
    set laststatus=2 " 常にステータスライン表示.
    let g:vimrc_active_winid = win_getid()
    let g:vimrc_stl_buf_total = ':1'

    augroup vimrc_statusline
        autocmd!
        autocmd WinEnter,TabEnter
                    \ * let g:vimrc_active_winid = win_getid() | redrawstatus
        autocmd VimEnter,BufAdd,BufDelete,BufWipeout,BufHidden,BufUnload
                    \ * call s:StlBufCount()
        autocmd OptionSet buflisted call s:StlBufCount()
        autocmd BufEnter,BufWritePost * call s:StlFileSize('%:p')
    augroup END

    set statusline=[%n%{win_getid()==get(g:,'vimrc_active_winid',-1)?
                \g:vimrc_stl_buf_total:''}]
    set statusline+=\ %{get(w:,'vimrc_stl_file_size','')}%<%F%m
    set statusline+=\ %{%win_getid()==get(g:,'vimrc_active_winid',-1)?'%y':''%}
    set statusline+=%=
    set statusline+=%{(&fenc==#'utf-8'?'':'['.&fenc.']').(&bomb?'[BOM]':'')}
    set statusline+=%{(&ff==#'unix'?'':'['.&ff.']')}
    set statusline+=\ %-6.(%l:%v%)\ %-4.P
endif

