" --- Smart relativenumber -------------------------------------------
function! s:RelNumRestore() abort
    if &number && mode() !=# 'i' && !&relativenumber
        set relativenumber
    endif
endfunction
function! s:RelNumOnScroll() abort
    if !&number | return | endif
    if &relativenumber | set norelativenumber | endif

    " 700msスクロールが止まったら相対行に戻す(Insert mode以外)j
    call s:DeferLatest('s:RelNumOnScroll', 700, function('s:RelNumRestore'))
endfunction

" --- Remove ro from formatoptions -----------------------------------
function! s:RemoveROFromFO(bufnr) abort
    let l:bufnr = str2nr(a:bufnr)
    if !bufexists(l:bufnr) | return | endif
    if !empty(getbufvar(l:bufnr, '&buftype')) | return | endif
    let fo = getbufvar(l:bufnr, '&formatoptions')
    let fo2 = substitute(fo, '[ro]', '', 'g')
    if fo2 ==# fo | return | endif
    call setbufvar(l:bufnr, '&formatoptions', fo2)
endfunction

" --- Statusline -----------------------------------------------------
function! s:StlBufCount__Update() abort
    let g:vimrc_stl_buf_total = ':' . len(filter(
                \ range(1, bufnr('$')), 'buflisted(v:val)'
                \ ))
    redrawstatus
endfunction
function! s:StlBufCount() abort
    call s:DeferLatest('s:StlBufCount', 50, function('s:StlBufCount__Update'))
endfunction

function! s:StlFileSize(file) abort
    let size = getfsize(expand(a:file))
    if size > 0
        let w:vimrc_stl_file_size = s:FmtBytes(size) . ' '
    else
        let w:vimrc_stl_file_size = ''
    endif
endfunction

